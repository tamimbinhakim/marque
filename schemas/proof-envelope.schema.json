{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marqueproto.org/schemas/proof-envelope.schema.json",
  "title": "Marque ProofEnvelope",
  "description": "Non-repudiation wrapper for SIGNED and QUALIFIED auth modes per §5.4 and §6.",
  "type": "object",
  "required": [
    "proof_version",
    "message_hash",
    "sender_signature",
    "sender_cert_chain"
  ],
  "properties": {
    "proof_version": { "type": "string", "const": "marque-proof/1" },
    "message_hash": {
      "type": "object",
      "required": ["alg", "value"],
      "properties": {
        "alg":   { "type": "string", "enum": ["sha-256", "sha-384", "sha-512"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    },
    "sender_signature": {
      "type": "object",
      "required": ["alg", "signed_by_key"],
      "properties": {
        "alg":           { "type": "string" },
        "classical":     { "type": "string" },
        "pq":            { "type": "string" },
        "signed_by_key": { "type": "string" }
      }
    },
    "sender_cert_chain": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["subject", "issuer", "signature"],
        "properties": {
          "subject":        { "type": "string" },
          "issuer":         { "type": "string" },
          "not_before":     { "$ref": "./_defs/common.schema.json#/$defs/rfc3339_utc" },
          "not_after":      { "$ref": "./_defs/common.schema.json#/$defs/rfc3339_utc" },
          "signature":      { "type": "string" },
          "kel_event_ref":  {
            "type": "object",
            "properties": {
              "seq":  { "type": "integer", "minimum": 0 },
              "hash": { "$ref": "./_defs/common.schema.json#/$defs/blake3_256" }
            }
          }
        }
      }
    },
    "qualified_certificate": {
      "type": "object",
      "description": "Required at Certified tier. Issued by an eIDAS-listed QTSP.",
      "required": ["issuer", "subject", "bound_to_did", "cades_profile", "pem"],
      "properties": {
        "issuer":         { "type": "string" },
        "subject":        { "type": "string" },
        "bound_to_did":   { "$ref": "./_defs/common.schema.json#/$defs/did_mail" },
        "cades_profile":  { "type": "string", "enum": ["B-B", "B-T", "B-LT", "B-LTA"] },
        "pem":            { "type": "string" },
        "trust_list_snapshot_ref": {
          "type": "string",
          "format": "uri",
          "description": "URL to the historical trust-list snapshot at signing time, per §6.7a."
        }
      }
    },
    "rfc3161_timestamp": {
      "type": "object",
      "properties": {
        "tsa":      { "type": "string", "format": "uri" },
        "policy":   { "type": "string" },
        "hash_alg": { "type": "string" },
        "time":     { "$ref": "./_defs/common.schema.json#/$defs/rfc3339_utc" },
        "token":    { "type": "string" }
      }
    },
    "frost_threshold_signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signer_label", "signature"],
        "properties": {
          "signer_label":        { "type": "string" },
          "signer_did":          { "$ref": "./_defs/common.schema.json#/$defs/did_mail" },
          "qtsp_trust_list_ref": { "type": "string", "format": "uri" },
          "signature":           { "type": "string" }
        }
      }
    },
    "opentimestamps": {
      "type": "object",
      "properties": {
        "ots_file":                     { "type": "string" },
        "calendar_urls":                { "type": "array", "items": { "type": "string", "format": "uri" } },
        "bitcoin_block_height_expected": { "type": "integer", "minimum": 0 }
      }
    },
    "archive_timestamps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tsa":   { "type": "string", "format": "uri" },
          "time":  { "$ref": "./_defs/common.schema.json#/$defs/rfc3339_utc" },
          "token": { "type": "string" }
        }
      }
    },
    "delivery_receipt": {
      "type": "object",
      "properties": {
        "state":         { "$ref": "./_defs/common.schema.json#/$defs/non_delivery_state" },
        "delivered_at":  { "$ref": "./_defs/common.schema.json#/$defs/rfc3339_utc" },
        "recipient_provider": { "type": "string" },
        "recipient_provider_signature": { "type": "string" },
        "read_at":       { "$ref": "./_defs/common.schema.json#/$defs/rfc3339_utc" },
        "read_receipt_signature": { "type": "string" },
        "transparency_log_entry": {
          "type": "object",
          "properties": {
            "log":                  { "type": "string", "format": "uri" },
            "log_index":            { "type": "integer", "minimum": 0 },
            "inclusion_proof_hash": { "type": "string" }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "description": "When cades_profile is present in qualified_certificate, the cert itself must be present (guards against partial-object injection).",
      "if":   { "properties": { "qualified_certificate": { "required": ["cades_profile"] } } },
      "then": { "properties": { "qualified_certificate": { "required": ["pem", "bound_to_did"] } } }
    }
  ]
}
